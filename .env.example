# GRACE CRM Environment Variables
# Copy this file to .env.local and fill in your values
#
# For Vercel deployment, set these in the Vercel dashboard:
#   Settings → Environment Variables

# ===========================================
# FRONTEND VARIABLES (prefixed with VITE_)
# ===========================================

# --- Supabase (Database) - REQUIRED ---
# Get from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Clerk (Authentication) - REQUIRED for production ---
# Get from: https://dashboard.clerk.com → API Keys
# Without Clerk, app blocks access in production
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- Stripe (Payments) - Optional ---
# Get from: https://dashboard.stripe.com/apikeys
# Only the PUBLISHABLE key goes here; secret key is backend-only
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Email sender config (non-secret) ---
VITE_EMAIL_FROM_ADDRESS=noreply@yourdomain.com
VITE_EMAIL_FROM_NAME=Grace Community Church

# --- Demo mode (development only) ---
# NEVER set to true in production!
# VITE_ENABLE_DEMO_MODE=false

# --- Sentry (Error monitoring) - Optional ---
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# Leave blank to disable. PII redaction is hard-coded in src/lib/observability/sentry.ts.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_RELEASE=

# --- PostHog (Analytics + Feature Flags) - Optional ---
# Get from: https://app.posthog.com → Project Settings → Project API Key
# VITE_POSTHOG_HOST defaults to https://us.i.posthog.com.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
# Server-side PostHog admin (for right-to-be-forgotten propagation in
# /api/consents/erase). When both are set, erasure deletes the person + events
# from PostHog; unset → the erase endpoint reports posthog: not_configured.
# POSTHOG_API_HOST is the personal-API host (NOT ingestion), default https://us.posthog.com.
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_API_HOST=

# ===========================================
# BACKEND VARIABLES (server-side only)
# ===========================================
# These are used by the Express API server (api/_server.ts).
# On Vercel, set them in the dashboard alongside VITE_ vars.
# Locally, add them to .env.local (never commit real keys).

# --- Stripe secret key ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe Connect: each church's own connected Express account is stored on
# churches.stripe_connect_account_id / stripe_connect_charges_enabled (set
# via the Connect onboarding flow, not an env var). No additional
# STRIPE_CONNECT_* env var is required — the platform account above is
# what creates the destination charges/subscriptions.

# --- i2c Impact Card / neobank (api/_lib/i2c/) ---
# I2C_LIVE=true switches api/_lib/i2c/index.ts from the deterministic mock
# adapter to the live adapter. As of this writing the live adapter
# (api/_lib/i2c/live-adapter.ts) is an unimplemented stub that throws —
# see TECH_DEBT.md TD-036. Leave I2C_LIVE unset/false; every KYC/card/
# interchange row in the database today is mock-adapter data, never
# represent it as live.
I2C_LIVE=false
I2C_API_KEY=

# --- Resend (Email service) ---
RESEND_API_KEY=re_xxx

# --- Twilio (SMS service) ---
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# --- Clerk (backend token verification) ---
CLERK_SECRET_KEY=sk_test_xxx

# --- Google Gemini (AI features, including the member GRACE assistant) ---
GEMINI_API_KEY=your-gemini-api-key

# --- OpenAI Moderation (input/output safety gate for AI features) ---
# Used by api/_lib/ai/moderation.ts. Without this set, moderation silently
# no-ops (fails open) rather than blocking the AI path — every AI feature
# still works, it's just unmoderated. Set this in any deployment that
# exposes AI to real members (e.g. the "Ask GRACE" member assistant).
OPENAI_API_KEY=sk-xxx

# --- Hermes (self-hosted OpenAI-compatible fallback provider) ---
# Optional. api/_lib/aiProviders.ts falls back to this when Gemini quota
# is hit. Leave unset to disable the fallback (Gemini failures just fail).
HERMES_API_URL=
HERMES_API_KEY=
HERMES_MODEL=
HERMES_API_PATH=

# --- Public AI demo access (unauthenticated /api/ai/generate) ---
# NEVER set to true in production — allows unauthenticated calls to the
# generic AI generate endpoint, metered against DEMO_CHURCH_ID. Off by
# default. Unrelated to the member GRACE assistant (/api/portal/assistant),
# which always requires a resolved member identity.
DEMO_AI_ACCESS=false

# --- ElevenLabs (Grace voice — server-side only) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: proxy TTS through member portal when key is not set locally
GRACE_TTS_UPSTREAM_URL=https://grace-crm.dev/api/grace/tts
# Optional overrides (defaults shown)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# --- NewsAPI (Sunday Prep) ---
NEWS_API_KEY=your-newsapi-key

# --- Server config ---
PORT=3001
FRONTEND_URL=http://localhost:5173
# Full URL to the STAFF app including any path prefix — used for deep
# links in staff notifications (crisis alerts). Falls back to
# FRONTEND_URL + '/app', which is correct for the Central Henderson
# domain but wrong for root-mounted hosts. Example:
# STAFF_APP_URL=https://gracecrm-centralhenderson.org/app
STAFF_APP_URL=

# --- Cron auth ---
# Required in production: Vercel's cron scheduler sends this as a
# Bearer token automatically once the env var is set on the project.
# Cron routes 503 loudly when it's missing (api/_lib/cronAuth.ts) —
# never fail open. Generate with: openssl rand -base64 32
CRON_SECRET=

# --- Sentry (server) - Optional ---
# Use a different DSN from the client; do not reuse VITE_SENTRY_DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# 0.0 - 1.0; default 0.1 in production, 0 elsewhere.
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=

# --- Durable rate limiting (Upstash Redis) ---
# When BOTH are set, api rate limits become global across serverless
# instances (a real backstop against distributed floods). When unset, the
# limiter falls back to per-instance in-memory counting — safe, just softer.
# Provision via Vercel → Marketplace → Upstash (auto-injects these vars).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cross-tenant isolation smoke test (CI/staging only) ---
# Required by tools/cross-tenant-smoke.test.ts AFTER migration 011 lands.
# Two real Clerk-issued tokens for users in two different test tenants.
# Leave blank to skip the test (default).
SUPABASE_TEST_URL=
SUPABASE_TEST_ANON_KEY=
SUPABASE_TEST_TENANT_A_TOKEN=
SUPABASE_TEST_TENANT_B_TOKEN=
SUPABASE_TEST_TENANT_A_ID=
SUPABASE_TEST_TENANT_B_ID=

# --- Shared-platform-foundation smoke test (CI/staging only) ---
# Required by tools/shared-foundation-smoke.test.ts for member-self-access
# checks AFTER migrations 031-038 land. A Clerk-issued token for a portal
# member (people.clerk_user_id-linked, portal_enabled=true, NOT a staff
# user) in tenant A, and that member's people.id.
# Leave blank to skip those specific checks (default).
SUPABASE_TEST_TENANT_A_MEMBER_TOKEN=
SUPABASE_TEST_TENANT_A_MEMBER_PERSON_ID=

# --- Audit middleware ---
# When the server runs behind a proxy (Vercel, ALB), set to true so
# X-Forwarded-For is honored when recording client IPs in audit_logs.
# Default (unset) trusts only the socket address — safe by default.
TRUST_PROXY=

# ===========================================
# DEPLOYMENT CHECKLIST
# ===========================================
# 1. Set all VITE_ vars in Vercel → Environment Variables
# 2. Set all backend vars in Vercel → Environment Variables
# 3. Run Supabase migrations (supabase/migrations/*.sql)
# 4. Enable Row Level Security on all Supabase tables
# 5. Configure Clerk auth (create app, set redirect URLs)
# 6. Configure Stripe webhooks → point to your-domain/webhooks
# 7. Verify: curl https://your-domain/api/health

# D-ID Studio — per-leader overrides in centralHendersonLeaders.ts; env used as fallback (James Wilson demo)
VITE_DID_AGENT_ID=
VITE_DID_CLIENT_KEY=
