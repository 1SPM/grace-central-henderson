{
  "name": "grace-crm",
  "version": "1.0.0",
  "description": "GRACE - Growth, Relationships, Attendance, Community, Engagement. Church CRM that never loses a visitor.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx --env-file=.env.local api/_server.ts",
    "dev:full": "npm run dev:api & npm run dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:rls": "tsx tools/lint-rls.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.5",
